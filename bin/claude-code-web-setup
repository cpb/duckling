#!/bin/sh
# Installs per-tool dependencies before Claude Code tool calls, using receipt
# files in tmp/claude-web-receipts/ as a fast-path cache so only the first
# call per session pays installation cost.
#
# Only reached in Claude Code web sessions — the hook command in settings.json
# short-circuits on CLAUDE_CODE_REMOTE != true before exec'ing this script.
set -eu

INPUT=$(cat)
TOOL_NAME=$(printf '%s' "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null || true)

RECEIPTS_DIR="tmp/claude-web-receipts"
mkdir -p "$RECEIPTS_DIR"

install_gems() {
  local lock_hash receipt
  lock_hash=$(sha256sum Gemfile.lock 2>/dev/null | cut -c1-8 || echo "no-lock")
  receipt="$RECEIPTS_DIR/gems-$lock_hash"

  [ -f "$receipt" ] && return 0

  bundle install
  touch "$receipt"
}

compile_extension() {
  local src_hash receipt
  src_hash=$(
    find ext/duckling -type f \( -name '*.rs' -o -name '*.toml' -o -name '*.lock' -o -name 'extconf.rb' \) \
      | sort \
      | xargs sha256sum \
      | sha256sum \
      | cut -c1-8
  )
  receipt="$RECEIPTS_DIR/ext-$src_hash"

  [ -f "$receipt" ] && return 0

  bundle exec rake compile
  touch "$receipt"
}

install_hk() {
  local hk_version receipt
  hk_version=$(grep -m1 -o 'hk@[0-9][0-9.]*' hk.pkl | cut -d@ -f2)
  receipt="$RECEIPTS_DIR/hk-$hk_version"

  if [ -f "$receipt" ] && command -v hk > /dev/null 2>&1; then
    return 0
  fi

  if ! command -v hk > /dev/null 2>&1; then
    if command -v brew > /dev/null 2>&1; then
      brew install hk
    else
      curl -fsSL \
        "https://github.com/jdx/hk/releases/download/v${hk_version}/hk-x86_64-unknown-linux-gnu.tar.gz" \
        | tar -xz -C /usr/local/bin hk
    fi
  fi

  touch "$receipt"
}

install_hk_hooks() {
  local receipt="$RECEIPTS_DIR/hk-hooks"
  [ -f "$receipt" ] && return 0

  hk install
  touch "$receipt"
}

case "$TOOL_NAME" in
  Edit|Write)
    install_gems
    compile_extension
    install_hk
    install_hk_hooks
    ;;
esac
